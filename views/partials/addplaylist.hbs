<form class="ui stacked segment form" action="/dashboard/addplaylist" method="POST">
  <div class="ui two column grid" style="margin-bottom: .25rem;">
    <div class="column">
      <div class="field">
        <label>Title</label>
        <input placeholder="Title" type="text" name="title" autofocus required>
      </div>
    </div>
    <div class="column">
      <div class="field">
        <label>Rating</label>
        <input type="range" name="rating" min="1" max="5" required style="width:100%;">
      </div>
    </div>
  </div>
  <button class="ui blue submit button">Add Playlist</button>
</form>
